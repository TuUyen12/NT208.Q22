APP_NAME="Tử Vi API"
DEBUG=false

# Postgres
DATABASE_URL=postgresql+asyncpg://tuvi:tuvi@db:5432/tuvi

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_LONG_RANDOM_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# OAuth2 — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://yourdomain.com/api/v1/auth/google/callback

# OAuth2 — Facebook
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=https://yourdomain.com/api/v1/auth/facebook/callback

# AES-256 key for dob_solar + birth_hour encryption (32-byte hex = 64 hex chars)
# ⚠️ THAY KEY NÀY TRƯỚC KHI DEPLOY — sinh bằng: python3 -c "import secrets; print(secrets.token_hex(32))"
# ⚠️ KHÔNG dùng key toàn số 0 — decrypt sẽ fail nếu data được encrypt bằng key khác
FIELD_ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_secrets_token_hex_32

# External AI service
AI_SERVICE_URL=https://api.anthropic.com/v1/messages
AI_SERVICE_API_KEY=

# CORS — comma-separated origins
ALLOWED_ORIGINS=["http://localhost:5173"]

# Email — Google SMTP
# Dùng Gmail App Password (không phải mật khẩu đăng nhập Gmail)
# Bật tại: https://myaccount.google.com/apppasswords  (cần bật 2FA trước)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx